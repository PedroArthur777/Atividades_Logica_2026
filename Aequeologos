// define o tamanho
using System;

Console.Write("Escolha o tamanho do lado: ");
int.TryParse(Console.ReadLine(), out int lado);
int rodadas = 0;

while (rodadas < 3)
{
    // calculo lado
    if (lado != 0)
    {
        Console.WriteLine($"A area de {lado} é {lado * lado}");
        rodadas++;
    }
    else
    {
        Console.WriteLine("Numero invalido");
        rodadas = 3;
    }
}
// fofuxo
Console.Write("deina um raio em metros: ");
float.TryParse(Console.ReadLine(), out float raio);
double area = 3.14 * (raio * raio);
if (area >= 10)
{
    Console.WriteLine($"Você conseguiu enfrentar a maldição do infoxuxo com o resultado: {area}");
}
else
{
    Console.WriteLine($"Você vivera amaldiçoado para sempre pois seu resultado deu menos de 10: {area}");
}

